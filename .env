# Ordnerstruktur
WATCH_DIR=./eingang
OUTPUT_DIR=./verarbeitet
NO_GPS_DIR=./ohne_gps
ERROR_DIR=./fehler
LOG_DIR=./logs

# Nominatim API
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# WICHTIG: Eindeutiger User-Agent
USER_AGENT=FotoDokuWatchfolder/1.0 (tim.schumacher@intakt-cs.de)

# Rate Limit (Policy: max 1 Request / Sekunde)
REQUEST_INTERVAL_MS=1100

# Verarbeitung
PROCESS_DELAY_MS=3000

# Retry-Verhalten
RETRY_COUNT=2
RETRY_DELAY_MS=2500

# Sprache für Adressen
ACCEPT_LANGUAGE=de
