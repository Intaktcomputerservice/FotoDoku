{
  "name": "fotodoku",
  "version": "1.0.0",
  "description": "FotoDoku als lokale Desktop-Anwendung für Bildverarbeitung mit EXIF/GPS",
  "main": "electron/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "start:node": "node index.js",
    "build:win": "npm run clean && electron-builder --win nsis",
    "dev": "electron .",
    "dist": "npm run clean && electron-builder",
    "clean": "node -e \"require('fs').rmSync('dist',{ recursive: true, force: true })\""
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "dotenv": "^16.6.1",
    "electron": "^36.0.0",
    "exiftool-vendored": "^30.0.0"
  },
  "devDependencies": {
    "electron-builder": "^25.1.8",
    "rimraf": "^5.0.10"
  },
  "build": {
    "appId": "de.fotodoku.desktop",
    "productName": "FotoDoku",
    "files": [
      "electron/**/*",
      "backend/**/*",
      "frontend/**/*",
      "package.json",
      "!**/*.log",
      "!**/logs/**",
      "!**/tmp/**",
      "!**/temp/**",
      "!**/__tests__/**",
      "!**/*.test.*",
      "!**/*.spec.*"
    ],
    "win": {
      "target": "nsis"
    },
    "asar": true,
    "directories": {
      "output": "dist"
    }
  }
}
